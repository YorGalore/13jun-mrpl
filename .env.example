LLM_PROVIDER=gemini

LLM_MODELS=gemini-2.5-flash, gemini:gemini-2.0-flash, ollama:llama3.2:3b
DEFAULT_MODEL=gemini:gemini-2.5-flash

GEMINI_API_KEY=A<GEMINI_API_KEY>
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PREDICT=1024
OLLAMA_NUM_CTX=8192
LLM_TIMEOUT=120


# ===== SEPSES CSKG / SPARQL =====
SEPSES_PUBLIC_ENDPOINT=https://sepses.ifs.tuwien.ac.at/sparql
SEPSES_SPARQL_TIMEOUT=20

# ===== Cadangan Virtuoso lokal (dipakai bila SEPSES publik gagal/kosong) =====
SEPSES_ENABLE_LOCAL_FALLBACK=true
SEPSES_LOCAL_ENDPOINT=http://localhost:8890/sparql
SEPSES_LOCAL_GRAPH=http://sepses.local

MITRE_DATASET_PATH=modul_a3/enterprise-attack.json

LOGS_FILE=
CHROMA_DIR=

BACKEND_PORT=8000
FRONTEND_ORIGINS=http://localhost:3000
